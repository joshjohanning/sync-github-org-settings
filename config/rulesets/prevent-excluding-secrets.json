{
  "name": "prevent ppl from excluding secrets",
  "target": "push",
  "enforcement": "active",
  "conditions": {
    "repository_property": {
      "exclude": [],
      "include": []
    }
  },
  "rules": [
    {
      "type": "file_path_restriction",
      "parameters": {
        "restricted_file_paths": [".github/secret_scanning.yml"]
      }
    }
  ],
  "bypass_actors": [
    {
      "actor_id": null,
      "actor_type": "OrganizationAdmin",
      "bypass_mode": "always"
    }
  ]
}
