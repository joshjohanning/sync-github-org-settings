{
  "name": "Required workflow: Dependency Review",
  "target": "branch",
  "enforcement": "evaluate",
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": ["refs/heads/main"]
    },
    "repository_property": {
      "exclude": [
        {
          "name": "visibility",
          "source": "system",
